<!DOCTYPE html PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN">
<html>
<head>
<meta http-equiv="Content-Type" content="text/html; charset=iso-8859-1">
<title>Maison Maxine</title>
<link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,300;1,300;1,400&display=swap" rel="stylesheet">
<style type="text/css">
body {
  margin: 0;
  padding: 0;
  background-color: #f5eaf2;
  background-image: url("bg.png");
  background-size: 520px auto;
  background-repeat: repeat;
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 13px;
  color: #7a3858;
}

table { border-collapse: collapse; }

/* OUTER WRAPPER */
#outer {
  width: 780px;
  margin: 22px auto;
  background-color: #f0c8e0;
  border: 6px solid #d488b8;
  padding: 9px;
}

#inner-border {
  border: 4px solid #e8a0cc;
  background-color: #faeaf4;
  padding: 0;
}

/* TOP BAR */
#topbar {
  background-color: #f8d8ee;
  border-bottom: 3px solid #dd88bb;
  padding: 8px 14px;
  width: 100%;
}

.logo-oval {
  background-color: #ffffff;
  border: 3px solid #cc5599;
  border-radius: 50px;
  -moz-border-radius: 50px;
  padding: 5px 22px 8px;
  display: inline-block;
  position: relative;
  text-align: center;
}
.logo-star {
  color: #cc5599;
  font-size: 20px;
  position: absolute;
  top: -10px;
  left: -6px;
}
.logo-script {
  font-family: 'Great Vibes', cursive;
  font-size: 38px;
  color: #b83380;
  line-height: 1;
  display: block;
}
.logo-tm {
  font-size: 8px;
  color: #aa4070;
  vertical-align: super;
  font-family: Georgia, serif;
}

.havefun-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 20px;
  font-style: italic;
  color: #993377;
  letter-spacing: 1px;
}

.fng-banner {
  background-color: #ffffff;
  border: 3px solid #e8c850;
  border-radius: 12px;
  -moz-border-radius: 12px;
  padding: 5px 20px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 17px;
  font-style: italic;
  color: #cc4488;
  font-weight: 300;
  white-space: nowrap;
  display: inline-block;
  letter-spacing: 0.5px;
}

/* STRIPE SIDES */
.stripe-col {
  width: 16px;
  background-image: repeating-linear-gradient(
    to bottom,
    #ee88bb 0px, #ee88bb 16px,
    #ffffff 16px, #ffffff 32px
  );
}

/* NAV COLUMN */
#nav-col {
  width: 196px;
  background-color: #f8d8f0;
  border-right: 2px solid #ddaacc;
  vertical-align: top;
  padding: 10px 8px;
}

.nav-row {
  margin-bottom: 6px;
}

.nav-icon-box {
  width: 52px;
  height: 48px;
  background-color: #f0b0d8;
  border: 2px solid #cc6699;
  border-right: none;
  border-radius: 8px 0 0 8px;
  -moz-border-radius: 8px 0 0 8px;
  vertical-align: middle;
  text-align: center;
  line-height: 48px;
  font-size: 22px;
  overflow: hidden;
}

.nav-btn {
  background-color: #e070b0;
  background-image: -webkit-gradient(linear, left top, left bottom, from(#ee99cc), to(#cc5599));
  background-image: -moz-linear-gradient(top, #ee99cc, #cc5599);
  background-image: linear-gradient(to bottom, #ee99cc, #cc5599);
  border: 2px solid #bb4488;
  border-radius: 0 18px 18px 0;
  -moz-border-radius: 0 18px 18px 0;
  padding: 6px 12px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  font-style: italic;
  font-weight: 300;
  color: #ffffff;
  text-shadow: 0 1px 2px rgba(100,20,60,0.5);
  text-align: center;
  cursor: pointer;
  vertical-align: middle;
  line-height: 1.3;
  width: 126px;
  letter-spacing: 0.5px;
}
.nav-btn:hover {
  background-image: linear-gradient(to bottom, #ffaadd, #dd66aa);
}

/* SCENE */
#scene {
  vertical-align: top;
  position: relative;
  overflow: hidden;
}

.scene-container {
  width: 100%;
  height: 370px;
  position: relative;
  overflow: hidden;
  background-color: #f8eef6;
  background-image: repeating-linear-gradient(
    90deg,
    rgba(255,255,255,0.55) 0px, rgba(255,255,255,0.55) 20px,
    transparent 20px, transparent 40px
  );
}

/* Pink stripe top of scene */
.scene-topstripe {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 10px;
  background-image: repeating-linear-gradient(
    to right,
    #ee88bb 0px, #ee88bb 18px,
    #ffffff 18px, #ffffff 36px
  );
  z-index: 10;
}

/* TAGLINE */
.tagline {
  position: absolute;
  top: 22px;
  left: 0; right: 0;
  text-align: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-style: italic;
  color: #993377;
  letter-spacing: 1.5px;
}

/* BULLET POINTS */
.bullets {
  position: absolute;
  top: 58px;
  left: 30px;
  list-style: none;
}
.bullets li {
  font-family: 'Cormorant Garamond', serif;
  font-size: 16px;
  font-style: italic;
  color: #7a3858;
  letter-spacing: 0.5px;
  margin-bottom: 14px;
}

/* PHOTO CARDS */
.photo-card {
  position: absolute;
  background-color: #faf6ee;
  border: 3px solid #e8dece;
  border-radius: 8px;
  -moz-border-radius: 8px;
  padding: 7px 7px 26px;
  box-shadow: 2px 4px 12px rgba(160,80,120,0.18);
}

/* dashed inner border on polaroid */
.photo-card-inner {
  position: relative;
  width: 100%;
  height: 100%;
  border: 2px dashed #d8c8b8;
  border-radius: 4px;
  -moz-border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42px;
  overflow: hidden;
}

/* photo placeholder fills */
.fill-beach {
  background: linear-gradient(160deg, #88c8e8 30%, #d8e8c0 100%);
  background: -moz-linear-gradient(top left, #88c8e8 30%, #d8e8c0 100%);
}
.fill-drink {
  background: linear-gradient(160deg, #98c8e0 20%, #eec8d8 100%);
  background: -moz-linear-gradient(top left, #98c8e0 20%, #eec8d8 100%);
}
.fill-dark {
  background: linear-gradient(160deg, #281520 0%, #6a2840 100%);
  background: -moz-linear-gradient(top left, #281520 0%, #6a2840 100%);
}

.card-caption {
  position: absolute;
  bottom: 6px;
  left: 0; right: 0;
  text-align: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 12px;
  font-style: italic;
  color: #8a5068;
}

/* card positions - mimicking original stacked polaroids */
.card-1 {
  width: 178px;
  height: 248px;
  top: 40px;
  right: 210px;
  transform: rotate(-4deg);
  -webkit-transform: rotate(-4deg);
  -moz-transform: rotate(-4deg);
  z-index: 2;
}
.card-2 {
  width: 192px;
  height: 268px;
  top: 14px;
  right: 60px;
  transform: rotate(2deg);
  -webkit-transform: rotate(2deg);
  -moz-transform: rotate(2deg);
  z-index: 3;
}
.card-3 {
  width: 154px;
  height: 200px;
  top: 188px;
  right: 22px;
  transform: rotate(5deg);
  -webkit-transform: rotate(5deg);
  -moz-transform: rotate(5deg);
  z-index: 4;
}

/* green sticky note labels on cards */
.card-label {
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  -webkit-transform: translateX(-50%);
  background-color: #e0eecc;
  border: 1px solid #c8d8a8;
  border-radius: 4px;
  -moz-border-radius: 4px;
  padding: 2px 10px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 11px;
  font-style: italic;
  color: #6a8840;
  white-space: nowrap;
  z-index: 5;
}

/* BOTTOM TAGLINE */
.bottom-tagline {
  position: absolute;
  bottom: 8px;
  left: 0; right: 0;
  text-align: center;
  font-family: 'Cormorant Garamond', serif;
  font-size: 15px;
  font-style: italic;
  color: #993377;
  letter-spacing: 1px;
}

/* FOOTER */
#footer {
  background-color: #f8d8ee;
  border-top: 3px solid #dd88bb;
  text-align: center;
  padding: 9px 20px;
  font-family: 'Cormorant Garamond', serif;
  font-size: 12px;
  font-style: italic;
  color: #7a3858;
  line-height: 1.7;
  letter-spacing: 0.3px;
}
#footer a { color: #aa4470; text-decoration: underline; }

/* instagram + cart icons in topbar */
.insta-icon { font-size: 20px; color: #993377; vertical-align: middle; }
.cart-wrap {
  font-family: 'Cormorant Garamond', serif;
  font-size: 14px;
  color: #7a3858;
  vertical-align: middle;
}
</style>
</head>
<body>

<table id="outer" cellpadding="0" cellspacing="0">
<tr><td>
<table id="inner-border" cellpadding="0" cellspacing="0" width="100%">

<!-- TOP BAR -->
<tr>
<td id="topbar">
  <table width="100%" cellpadding="0" cellspacing="0">
  <tr valign="middle">
    <td width="220">
      <span class="insta-icon">&#128247;</span>
      &nbsp;&nbsp;
      <div class="logo-oval" style="display:inline-block;">
        <span class="logo-star">&#9733;</span>
        <span class="logo-script">Maison Maxine<span class="logo-tm">TM</span></span>
      </div>
    </td>
    <td align="center">
      <span class="havefun-text">reimagine the pour.</span>
    </td>
    <td align="right" width="200">
      <span class="cart-wrap">&#128722;&nbsp;0</span>
      &nbsp;&nbsp;&nbsp;
      <div class="fng-banner">&#128196; the magazine! &#9658;</div>
    </td>
    <td width="8">&nbsp;</td>
  </tr>
  </table>
</td>
</tr>

<!-- MAIN ROW -->
<tr>
<td>
<table width="100%" cellpadding="0" cellspacing="0">
<tr>

  <!-- LEFT STRIPE -->
  <td class="stripe-col" width="16">&nbsp;</td>

  <!-- NAV -->
  <td id="nav-col" valign="top">
    <br>

    <div class="nav-row">
      <table cellpadding="0" cellspacing="0"><tr valign="middle">
        <td class="nav-icon-box" style="background-color:#f4b8d8;">🍷</td>
        <td class="nav-btn">home</td>
      </tr></table>
    </div>

    <div class="nav-row">
      <table cellpadding="0" cellspacing="0"><tr valign="middle">
        <td class="nav-icon-box" style="background-color:#d8eec8;">🌿</td>
        <td class="nav-btn">sustainability</td>
      </tr></table>
    </div>

    <div class="nav-row">
      <table cellpadding="0" cellspacing="0"><tr valign="middle">
        <td class="nav-icon-box" style="background-color:#f4c0d0;">🌹</td>
        <td class="nav-btn">compassion</td>
      </tr></table>
    </div>

    <div class="nav-row">
      <table cellpadding="0" cellspacing="0"><tr valign="middle">
        <td class="nav-icon-box" style="background-color:#f8e0b0;">👠</td>
        <td class="nav-btn">shop</td>
      </tr></table>
    </div>

    <br>
  </td>

  <!-- SCENE -->
  <td id="scene" valign="top">
    <div class="scene-container">
      <div class="scene-topstripe"></div>

      <!-- Tagline -->
      <div class="tagline">reimagining red wine for the modern muse</div>

      <!-- Bullet list -->
      <ul class="bullets">
        <li>red wine spritzers</li>
        <li>four whole ingredients</li>
        <li>napa valley cabernet</li>
        <li>5% to animals in need</li>
      </ul>

      <!-- Photo card 1: drink on beach -->
      <div class="photo-card card-1">
        <div class="card-label">malibu, ca</div>
        <div class="photo-card-inner fill-drink" style="height:192px;">🍷</div>
        <div class="card-caption">malibu, ca</div>
      </div>

      <!-- Photo card 2: girl smiling -->
      <div class="photo-card card-2">
        <div class="card-label">s.s. for m.m. &#10047;</div>
        <div class="photo-card-inner fill-beach" style="height:218px;">&#9728;</div>
        <div class="card-caption">s.s. for m.m. &#10047;</div>
      </div>

      <!-- Photo card 3: small dark close-up -->
      <div class="photo-card card-3">
        <div class="photo-card-inner fill-dark" style="height:154px; color:#e8c0b0; font-size:30px;">&#127773;</div>
      </div>

      <!-- Bottom tagline -->
      <div class="bottom-tagline">drink well. give back. be a muse.</div>

    </div>
  </td>

  <!-- RIGHT STRIPE -->
  <td class="stripe-col" width="16">&nbsp;</td>

</tr>
</table>
</td>
</tr>

<!-- FOOTER -->
<tr>
<td id="footer">
  <a href="#">copyright 2026 maison maxine</a><br>
  <a href="#">alcohol sales fulfilled and sold by eubel family vineyards</a>
</td>
</tr>

</table>
</td></tr>
</table>

</body>
</html>
